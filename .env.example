# =============================================================================
# AgentShield — Environment Variables
# Copy this file to .env and fill in required values before running.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — must be set before starting the stack
# -----------------------------------------------------------------------------

# Secret used to sign JWT tokens. Generate with:
#   openssl rand -hex 32
JWT_SECRET=

# Admin credentials for the dashboard
ADMIN_EMAIL=
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# PostgreSQL (have safe defaults for local dev)
# -----------------------------------------------------------------------------
POSTGRES_DB=agentshield
POSTGRES_USER=agentshield
POSTGRES_PASSWORD=agentshield

# -----------------------------------------------------------------------------
# LLM Backend — Ollama (local, completely free) — start with: OLLAMA_HOST=0.0.0.0 ollama serve
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://host.docker.internal:11434
DEFAULT_MODEL=ollama_chat/qwen3:4b

# -----------------------------------------------------------------------------
# LLM Backend — Cloud providers (uncomment to enable) — set any key(s) you want to use
# -----------------------------------------------------------------------------
# GROQ_API_KEY=gsk_...           # groq/llama-3.3-70b-versatile  (free tier)
# GEMINI_API_KEY=AIza...         # gemini/gemini-1.5-flash        (free tier)
# MISTRAL_API_KEY=...            # mistral/mistral-small-latest   (free tier)
# OPENAI_API_KEY=sk-...          # openai/gpt-4o-mini             (paid)
# ANTHROPIC_API_KEY=sk-ant-...   # anthropic/claude-3-5-haiku-*   (paid)


# -----------------------------------------------------------------------------
# Optional tuning
# -----------------------------------------------------------------------------
LOG_LEVEL=info
GRAFANA_ADMIN_PASSWORD=admin
# REDIS_PASSWORD=     # leave empty for no-auth dev setup
