# =============================================================================
# AgentShield — Environment Variables
# Copy this file to .env and fill in required values before running.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — must be set before starting the stack
# -----------------------------------------------------------------------------

# Secret used to sign JWT tokens. Generate with:
#   openssl rand -hex 32
JWT_SECRET=

# Admin credentials for the dashboard
ADMIN_EMAIL=
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# PostgreSQL (have safe defaults for local dev)
# -----------------------------------------------------------------------------
POSTGRES_DB=agentshield
POSTGRES_USER=agentshield
POSTGRES_PASSWORD=agentshield

# -----------------------------------------------------------------------------
# LLM Backend — Option A: Ollama (local, default)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://host.docker.internal:11434
DEFAULT_MODEL=llama3

# -----------------------------------------------------------------------------
# LLM Backend — Option B: Groq (cloud, uncomment to use)
# -----------------------------------------------------------------------------
# GROQ_API_KEY=gsk_...

# -----------------------------------------------------------------------------
# Optional tuning
# -----------------------------------------------------------------------------
LOG_LEVEL=info
GRAFANA_ADMIN_PASSWORD=admin
# REDIS_PASSWORD=   # leave empty for no-auth dev setup
