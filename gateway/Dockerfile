### Build stage
FROM golang:1.22-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -o /gateway ./cmd/gateway

### Run stage
FROM alpine:3.19

RUN apk add --no-cache ca-certificates wget

COPY --from=builder /gateway /gateway

EXPOSE 8080

CMD ["/gateway"]
